    "type-check": "tsc"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^/static/(.*)$": "<rootDir>/../../static/$1",
      "^/js/(.*)$": "<rootDir>/../../static/js/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
