{
  "name": "lvce-editor",
  "version": "0.0.0-dev",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "postinstall": "lerna bootstrap --ci && node scripts/postinstall.js",
    "test": "lerna run test",
    "dev": "nodemon",
    "e2e": "lerna run e2e",
    "lint": "eslint \"packages/shared-process/**/*.{ts,js}\"",
    "electron": "node packages/build/src/parts/RunElectron/RunElectron.ts",
    "type-check": "lerna run type-check",
    "build:static": "node packages/build/bin/build.ts --target=static",
    "build:static:ignore-icon-theme": "node packages/build/bin/build.ts --target=static --ignore-icon-theme",
    "build:server": "node packages/build/bin/build.ts --target=server",
    "build:electron:deb": "node packages/build/bin/build.ts --target=electron-deb",
    "build:electron:deb:x64": "node packages/build/bin/build.ts --target=electron-deb --arch=x64",
    "build:electron:deb:arm64": "node packages/build/bin/build.ts --target=electron-deb --arch=arm64",
    "build:electron:deb:armhf": "node packages/build/bin/build.ts --target=electron-deb --arch=armhf",
    "build:electron:mac:x64": "node packages/build/bin/build.ts --target=electron-builder-mac --arch=x64",
    "build:electron:mac:arm64": "node packages/build/bin/build.ts --target=electron-builder-mac --arch=arm64",
    "build:electron:windows:exe": "node packages/build/bin/build.ts --target=electron-builder-windows-exe",
    "build:electron:windows:exe:x64": "node packages/build/bin/build.ts --target=electron-builder-windows-exe --arch=x64",
    "build:electron:windows:exe:arm64": "node packages/build/bin/build.ts --target=electron-builder-windows-exe --arch=arm64",
    "build:electron:app-image": "node packages/build/bin/build.ts --target=electron-builder-app-image",
    "build:electron:app-image:x64": "node packages/build/bin/build.ts --target=electron-builder-app-image --arch=x64",
    "test-static-export": "node packages/build/src/parts/TestStaticExport/TestStaticExport.ts",
    "e2e:ci": "node packages/extension-host-worker-tests/src/_all.js --ci"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lvce-editor/lvce-editor.git"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.1",
    "eslint": "^10.7.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lerna": "^8.2.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "nodemonConfig": {
    "ignore": [
      "**/build/**",
      "**/misc/**",
      "**/playground/**",
      "**/static/**",
      "**/test/**",
      "**/dist/**",
      "**/distmin/**",
      "**/scripts/**",
      "**/node_modules/**",
      "**/coverage/**",
      "**/extensions/**",
      "**/renderer-worker/**",
      "**/renderer-process/**",
      "**/extension-host-worker/**",
      "**/.tmp/**"
    ],
    "exec": "node packages/server/bin/server.js"
  }
}
